# Local server settings. Copy to .env for development.
PORT=8000
VIS_ARENA_PUBLIC_BASE_URL=http://localhost:8000
VIS_ARENA_CORS_ORIGINS=http://localhost:8200,http://localhost:5173
VIS_ARENA_SECRET_KEY=dev-secret-change-me
VIS_ARENA_DB=.vis-arena/server.db
VIS_ARENA_STORAGE=.vis-arena/storage

# S3 or S3-compatible object storage for datasets, submissions, and artifacts.
VIS_ARENA_S3_BUCKET=vis-arena-dev
VIS_ARENA_S3_REGION=us-east-1
# VIS_ARENA_S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# Evaluation worker settings.
VIS_ARENA_EXECUTOR_MODE=local_docker
VIS_ARENA_EVALUATOR_IMAGE=mcr.microsoft.com/playwright/python:v1.60.0-noble
VIS_ARENA_EVALUATOR_NETWORK=bridge
VIS_ARENA_EVALUATOR_TIMEOUT_SECONDS=1800
VIS_ARENA_WORKER_API_TOKEN=dev-worker-token
VIS_ARENA_OPENAI_MODEL=gpt-4.1-mini
VIS_ARENA_LEGACY_PEER_REVIEW_ENABLED=false
VIS_ARENA_ROUNDS_ENABLED=false
VIS_ARENA_AUTO_START_PEER_REVIEW=false

# AWS Batch on Fargate executor settings. Set VIS_ARENA_EXECUTOR_MODE=aws_batch_fargate
# on the backend instance to submit each queued job to AWS Batch.
# VIS_ARENA_AWS_BATCH_REGION=us-east-1
# VIS_ARENA_AWS_BATCH_JOB_QUEUE=vis-arena-evaluator-queue
# VIS_ARENA_AWS_BATCH_JOB_DEFINITION=vis-arena-evaluator-runner
# VIS_ARENA_AWS_BATCH_RUNNER_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/vis-arena-evaluator-runner:latest
# VIS_ARENA_AWS_BATCH_JOB_VCPUS=2
# VIS_ARENA_AWS_BATCH_JOB_MEMORY=4096
# VIS_ARENA_AWS_BATCH_JOB_TIMEOUT_SECONDS=2400

# Enable only when the backend should broker OpenAI credentials during cloud evaluation.
VIS_ARENA_CLOUD_LLM_ENABLED=false
# VIS_ARENA_BROKERED_OPENAI_API_KEY=sk-...
